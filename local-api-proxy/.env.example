# Beispiel für erweiterte Umgebungsvariablen

# Server-Konfiguration
PORT=3000
NODE_ENV=development

# ==================== GRUNDLEGENDE APIs ====================

# News API (von https://newsapi.org)
NEWS_API_KEY=

# OpenWeather API (von https://openweathermap.org)
OPENWEATHER_API_KEY=

# ==================== SMART HOME ====================

# IFTTT Webhooks (von https://ifttt.com/maker)
IFTTT_WEBHOOK_KEY=

# Home Assistant
HOME_ASSISTANT_URL=http://192.168.1.100:8123
HOME_ASSISTANT_TOKEN=

# Tasmota Devices (direkte IP-Verbindung)
# Format: 192.168.1.50, 192.168.1.51, etc.

# ==================== KALENDER & ZEIT ====================

# Google Calendar (optional)
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_API_KEY=

# Zeitzone (Standard: Europe/Berlin)
DEFAULT_TIMEZONE=Europe/Berlin

# ==================== FINANZ APIs ====================

# Alpha Vantage (Aktien) - von https://www.alphavantage.co
ALPHA_VANTAGE_KEY=

# ==================== SPOTIFY ====================

# Spotify (optional - für vollständige Unterstützung)
SPOTIFY_TOKEN=

# ==================== WEITERE APIs ====================

# Rapid API Key (für erweiterte APIs)
RAPID_API_KEY=

# ==================== DEBUGGING ====================

# Debug Mode
DEBUG=false
